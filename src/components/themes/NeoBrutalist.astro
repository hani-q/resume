---
import { resume } from "../../data/resume";

const skillCategories = [
  { label: "PROGRAMMING", skills: resume.skills.programming, color: "bg-[#FFE500]", border: "border-black" },
  { label: "CLOUD & DEVOPS", skills: resume.skills.cloudDevops, color: "bg-[#FF006E]", border: "border-black", textColor: "text-white" },
  { label: "NETWORKING", skills: resume.skills.networking, color: "bg-[#3A86FF]", border: "border-black", textColor: "text-white" },
  { label: "AI / ML", skills: resume.skills.aiMl, color: "bg-black", border: "border-black", textColor: "text-[#FFE500]" },
];

const expBgColors = [
  "bg-[#FFE500]",
  "bg-white dark:bg-neutral-900",
  "bg-[#FF006E]/10",
  "bg-[#3A86FF]/10",
  "bg-[#FFE500]/30",
  "bg-white dark:bg-neutral-900",
];

const [eduInst, ...eduParts] = resume.education.split(" | ");
const eduDegree = eduParts[0] ?? "";
const eduSchool = eduParts[1] ?? "";
const eduLocation = eduParts[2] ?? "";
const eduYear = eduParts[3] ?? "";
---

<div data-theme="neo-brutalist" class="nb-root min-h-screen bg-[#FFE500] dark:bg-black text-black dark:text-white font-sans transition-colors duration-300">

  <!-- ═══════════════════════════ HERO HEADER ═══════════════════════════ -->
  <header class="border-b-4 border-black dark:border-[#FFE500] px-6 md:px-12 py-10 md:py-14">
    <div class="max-w-7xl mx-auto">

      <!-- Top bar: name + image -->
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">

        <!-- Name block -->
        <div class="flex-1">
          <div class="nb-badge inline-block bg-[#FF006E] text-white text-xs font-black uppercase tracking-widest px-3 py-1 border-2 border-black dark:border-white mb-4 shadow-[3px_3px_0px_0px_black] dark:shadow-[3px_3px_0px_0px_white]">
            Available for opportunities
          </div>
          <h1 class="nb-name text-6xl sm:text-7xl md:text-8xl font-black uppercase leading-none tracking-tight text-black dark:text-[#FFE500] nb-text-shadow">
            {resume.name.split(" ")[0]}<br />
            <span class="text-stroke">{resume.name.split(" ").slice(1).join(" ")}</span>
          </h1>
          <p class="mt-4 text-xl md:text-2xl font-black uppercase tracking-wide border-l-4 border-black dark:border-[#FFE500] pl-4 text-black dark:text-white">
            {resume.title}
          </p>
        </div>

        <!-- Profile image -->
        <div class="shrink-0">
          <div class="nb-profile-wrap relative w-48 h-48 md:w-56 md:h-56">
            <img
              src={resume.profileImage}
              alt={resume.name}
              class="w-full h-full object-cover border-4 border-black dark:border-[#FFE500] block nb-img-shadow"
            />
            <!-- Decorative corner accent -->
            <div class="absolute -bottom-3 -right-3 w-full h-full border-4 border-black dark:border-[#FFE500] -z-10 bg-[#FF006E]"></div>
          </div>
        </div>
      </div>

      <!-- Contact badges row -->
      <div class="mt-8 flex flex-wrap gap-3 items-center">
        <!-- Location -->
        <a
          href={`https://maps.google.com/?q=${encodeURIComponent(resume.location)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="nb-pill bg-white dark:bg-neutral-900 border-3 border-black dark:border-white font-bold text-sm px-4 py-2 shadow-[3px_3px_0px_0px_black] dark:shadow-[3px_3px_0px_0px_white] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[4px_4px_0px_0px_black] dark:hover:shadow-[4px_4px_0px_0px_white] transition-all flex items-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>
          </svg>
          {resume.location}
        </a>

        <!-- Email -->
        <a
          href={`mailto:${resume.email}`}
          class="nb-pill bg-[#FFE500] dark:bg-[#FFE500] text-black border-3 border-black font-bold text-sm px-4 py-2 shadow-[3px_3px_0px_0px_black] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[4px_4px_0px_0px_black] transition-all flex items-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          {resume.email}
        </a>

        <!-- Phone -->
        <a
          href={`tel:${resume.phone}`}
          class="nb-pill bg-white dark:bg-neutral-900 border-3 border-black dark:border-white font-bold text-sm px-4 py-2 shadow-[3px_3px_0px_0px_black] dark:shadow-[3px_3px_0px_0px_white] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[4px_4px_0px_0px_black] dark:hover:shadow-[4px_4px_0px_0px_white] transition-all flex items-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {resume.phone}
        </a>

        <!-- LinkedIn -->
        <a
          href={resume.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="nb-social-btn bg-[#3A86FF] text-white border-3 border-black shadow-[3px_3px_0px_0px_black] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[4px_4px_0px_0px_black] transition-all w-10 h-10 flex items-center justify-center shrink-0"
        >
          <svg role="img" viewBox="0 0 24 24" class="w-5 h-5 fill-current" xmlns="http://www.w3.org/2000/svg">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>

        <!-- X / Twitter -->
        <a
          href={resume.twitter}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X (Twitter)"
          class="nb-social-btn bg-black dark:bg-white text-white dark:text-black border-3 border-black dark:border-white shadow-[3px_3px_0px_0px_black] dark:shadow-[3px_3px_0px_0px_white] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[4px_4px_0px_0px_black] dark:hover:shadow-[4px_4px_0px_0px_white] transition-all w-10 h-10 flex items-center justify-center shrink-0"
        >
          <svg role="img" viewBox="0 0 24 24" class="w-4 h-4 fill-current" xmlns="http://www.w3.org/2000/svg">
            <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════ MAIN CONTENT ═══════════════════════════ -->
  <main class="max-w-7xl mx-auto px-6 md:px-12 py-10 space-y-10">

    <!-- ── OVERVIEW ── -->
    <section class="nb-section border-4 border-black dark:border-[#FFE500] bg-white dark:bg-neutral-900 shadow-[6px_6px_0px_0px_black] dark:shadow-[6px_6px_0px_0px_#FFE500]">
      <div class="nb-section-header bg-black dark:bg-[#FFE500] px-6 py-3 flex items-center gap-3">
        <span class="text-[#FFE500] dark:text-black font-black text-xs uppercase tracking-[0.2em]">01 /</span>
        <h2 class="text-[#FFE500] dark:text-black font-black text-lg uppercase tracking-widest">Overview</h2>
      </div>
      <div class="p-6 md:p-8">
        <p class="text-base md:text-lg leading-relaxed font-medium nb-summary" set:html={resume.overview.summary} />
        <ul class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-3">
          {resume.overview.highlights.map((h) => (
            <li class="flex gap-3 items-start">
              <span class="shrink-0 mt-1.5 w-3 h-3 bg-[#FF006E] border-2 border-black dark:border-white inline-block"></span>
              <span class="text-sm leading-relaxed font-medium">{h}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ── SKILLS ── -->
    <section class="nb-section border-4 border-black dark:border-[#FFE500] bg-white dark:bg-neutral-900 shadow-[6px_6px_0px_0px_black] dark:shadow-[6px_6px_0px_0px_#FFE500]">
      <div class="nb-section-header bg-[#FF006E] px-6 py-3 flex items-center gap-3">
        <span class="text-white font-black text-xs uppercase tracking-[0.2em]">02 /</span>
        <h2 class="text-white font-black text-lg uppercase tracking-widest">Skills</h2>
      </div>
      <div class="p-6 md:p-8 space-y-6">
        {skillCategories.map((cat) => (
          <div>
            <h3 class={`inline-block ${cat.color} ${cat.textColor ?? "text-black"} border-2 border-black dark:border-white text-xs font-black uppercase tracking-widest px-3 py-1 mb-3 shadow-[2px_2px_0px_0px_black] dark:shadow-[2px_2px_0px_0px_white]`}>
              {cat.label}
            </h3>
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill) => (
                <span class="nb-skill-tag border-2 border-black dark:border-neutral-500 bg-[#FFE500]/20 dark:bg-white/5 text-black dark:text-white font-bold text-sm px-3 py-1 shadow-[2px_2px_0px_0px_black] dark:shadow-[2px_2px_0px_0px_#FFE500] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[3px_3px_0px_0px_black] dark:hover:shadow-[3px_3px_0px_0px_#FFE500] transition-all cursor-default">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── EXPERIENCE ── -->
    <section class="nb-section border-4 border-black dark:border-[#FFE500] bg-white dark:bg-neutral-900 shadow-[6px_6px_0px_0px_black] dark:shadow-[6px_6px_0px_0px_#FFE500]">
      <div class="nb-section-header bg-[#3A86FF] px-6 py-3 flex items-center gap-3">
        <span class="text-white font-black text-xs uppercase tracking-[0.2em]">03 /</span>
        <h2 class="text-white font-black text-lg uppercase tracking-widest">Experience</h2>
      </div>
      <div class="divide-y-4 divide-black dark:divide-[#FFE500]">
        {resume.experience.map((job, i) => (
          <div class={`nb-exp-card p-6 md:p-8 ${expBgColors[i % expBgColors.length]} hover:-translate-x-1 hover:-translate-y-1 transition-transform duration-150`}>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-4">
              <div>
                <h3 class="text-xl md:text-2xl font-black uppercase leading-tight text-black dark:text-[#FFE500]">
                  {job.title}
                </h3>
                <p class="font-bold text-base mt-0.5 text-black dark:text-white">
                  {job.company}
                  <span class="font-medium text-sm opacity-70 ml-2">— {job.location}</span>
                </p>
              </div>
              <span class="shrink-0 inline-block bg-black dark:bg-[#FFE500] text-[#FFE500] dark:text-black text-xs font-black uppercase px-3 py-1 border-2 border-black dark:border-[#FFE500] whitespace-nowrap shadow-[2px_2px_0px_0px_#FF006E]">
                {job.period}
              </span>
            </div>
            <ul class="space-y-2">
              {job.bullets.map((bullet) => (
                <li class="flex gap-3 items-start text-sm leading-relaxed">
                  <span class="shrink-0 mt-1.5 w-2.5 h-2.5 bg-[#FF006E] border-2 border-black dark:border-white inline-block"></span>
                  <span class="font-medium">{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- ── BOTTOM ROW: CERTIFICATIONS + EDUCATION + INVOLVEMENT ── -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

      <!-- CERTIFICATIONS -->
      <section class="nb-section border-4 border-black dark:border-[#FFE500] bg-white dark:bg-neutral-900 shadow-[6px_6px_0px_0px_black] dark:shadow-[6px_6px_0px_0px_#FFE500]">
        <div class="nb-section-header bg-[#FFE500] dark:bg-[#FFE500] px-6 py-3 flex items-center gap-3">
          <span class="text-black font-black text-xs uppercase tracking-[0.2em]">04 /</span>
          <h2 class="text-black font-black text-lg uppercase tracking-widest">Certifications</h2>
        </div>
        <div class="p-6 flex flex-wrap gap-3">
          {resume.certifications.map((cert) => {
            const parts = cert.split(" | ");
            const certName = parts[0];
            const certIssuer = parts[1] ?? "";
            const certYear = parts[2] ?? "";
            return (
              <div class="nb-cert-badge border-2 border-black dark:border-neutral-500 bg-[#FFE500]/30 dark:bg-[#FFE500]/10 px-3 py-2 shadow-[3px_3px_0px_0px_black] dark:shadow-[3px_3px_0px_0px_#FFE500] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[4px_4px_0px_0px_black] dark:hover:shadow-[4px_4px_0px_0px_#FFE500] transition-all relative">
                <div class="absolute -top-2 -right-2 bg-[#FF006E] text-white text-[9px] font-black px-1.5 py-0.5 border border-black dark:border-white uppercase tracking-wider leading-none">
                  {certYear}
                </div>
                <p class="font-black text-xs uppercase leading-tight text-black dark:text-[#FFE500] pr-4">{certName}</p>
                <p class="text-[10px] font-bold uppercase tracking-wide text-black/60 dark:text-white/50 mt-0.5">{certIssuer}</p>
              </div>
            );
          })}
        </div>
      </section>

      <!-- EDUCATION + INVOLVEMENT stacked -->
      <div class="space-y-10">

        <!-- EDUCATION -->
        <section class="nb-section border-4 border-black dark:border-[#FFE500] bg-white dark:bg-neutral-900 shadow-[6px_6px_0px_0px_black] dark:shadow-[6px_6px_0px_0px_#FFE500]">
          <div class="nb-section-header bg-black dark:bg-[#FF006E] px-6 py-3 flex items-center gap-3">
            <span class="text-[#FFE500] dark:text-white font-black text-xs uppercase tracking-[0.2em]">05 /</span>
            <h2 class="text-[#FFE500] dark:text-white font-black text-lg uppercase tracking-widest">Education</h2>
          </div>
          <div class="p-6 md:p-8">
            <h3 class="font-black text-lg uppercase text-black dark:text-[#FFE500] leading-tight">{eduInst}</h3>
            <p class="font-bold text-sm mt-1 text-black dark:text-white">{eduDegree}</p>
            <p class="font-medium text-sm mt-0.5 opacity-70 text-black dark:text-white">{eduSchool}</p>
            <div class="mt-3 flex flex-wrap gap-2 items-center">
              <span class="inline-block bg-[#3A86FF] text-white text-xs font-black uppercase px-3 py-1 border-2 border-black dark:border-white shadow-[2px_2px_0px_0px_black] dark:shadow-[2px_2px_0px_0px_white]">
                {eduYear}
              </span>
              <span class="text-xs font-bold opacity-60 text-black dark:text-white">{eduLocation}</span>
            </div>
          </div>
        </section>

        <!-- COMMUNITY INVOLVEMENT -->
        <section class="nb-section border-4 border-black dark:border-[#FFE500] bg-white dark:bg-neutral-900 shadow-[6px_6px_0px_0px_black] dark:shadow-[6px_6px_0px_0px_#FFE500]">
          <div class="nb-section-header bg-[#FF006E] px-6 py-3 flex items-center gap-3">
            <span class="text-white font-black text-xs uppercase tracking-[0.2em]">06 /</span>
            <h2 class="text-white font-black text-lg uppercase tracking-widest">Involvement</h2>
          </div>
          <div class="p-6 md:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
              <div>
                <h3 class="font-black text-lg uppercase text-black dark:text-[#FFE500] leading-tight">{resume.involvement.organization}</h3>
                <p class="font-bold text-sm mt-0.5 text-black dark:text-white">
                  {resume.involvement.role}
                  <span class="font-medium opacity-70 ml-2">— {resume.involvement.location}</span>
                </p>
              </div>
              <span class="shrink-0 inline-block bg-black dark:bg-[#FFE500] text-[#FFE500] dark:text-black text-xs font-black uppercase px-3 py-1 border-2 border-black dark:border-[#FFE500] shadow-[2px_2px_0px_0px_#3A86FF] whitespace-nowrap">
                {resume.involvement.period}
              </span>
            </div>
            <ul class="space-y-2">
              {resume.involvement.bullets.map((b) => (
                <li class="flex gap-3 items-start text-sm leading-relaxed">
                  <span class="shrink-0 mt-1.5 w-2.5 h-2.5 bg-[#3A86FF] border-2 border-black dark:border-white inline-block"></span>
                  <span class="font-medium text-black dark:text-white">{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>

      </div>
    </div>

  </main>

  <!-- ═══════════════════════════ FOOTER ═══════════════════════════ -->
  <footer class="border-t-4 border-black dark:border-[#FFE500] mt-10 px-6 md:px-12 py-6">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-black text-xs uppercase tracking-widest text-black dark:text-[#FFE500]">
        {resume.name} &mdash; {new Date().getFullYear()}
      </p>
      <div class="flex gap-2 items-center">
        <span class="w-3 h-3 bg-[#FFE500] border-2 border-black dark:border-white inline-block"></span>
        <span class="w-3 h-3 bg-[#FF006E] border-2 border-black dark:border-white inline-block"></span>
        <span class="w-3 h-3 bg-[#3A86FF] border-2 border-black dark:border-white inline-block"></span>
        <span class="w-3 h-3 bg-black dark:bg-white border-2 border-black dark:border-white inline-block"></span>
      </div>
      <p class="font-bold text-xs uppercase tracking-wider opacity-60 text-black dark:text-white">
        Neo Brutalist Theme
      </p>
    </div>
  </footer>

</div>

<style>
  /* ── Custom border widths (Tailwind v4 doesn't ship border-3 by default) ── */
  .border-3 {
    border-width: 3px;
  }

  /* ── Name text shadow: big offset solid black ── */
  .nb-text-shadow {
    text-shadow: 5px 5px 0px #FF006E, 8px 8px 0px rgba(0,0,0,0.15);
  }

  :global(.dark) .nb-text-shadow {
    text-shadow: 5px 5px 0px #FF006E, 8px 8px 0px rgba(255, 229, 0, 0.25);
  }

  /* ── Hollow/outlined text for surname ── */
  .text-stroke {
    -webkit-text-stroke: 3px currentColor;
    color: transparent;
  }

  :global(.dark) .text-stroke {
    -webkit-text-stroke: 3px #FFE500;
    color: transparent;
  }

  /* ── Profile image offset shadow ── */
  .nb-img-shadow {
    box-shadow: 6px 6px 0px 0px #000;
  }

  :global(.dark) .nb-img-shadow {
    box-shadow: 6px 6px 0px 0px #FFE500;
  }

  /* ── Section header — flush border fix ── */
  .nb-section-header {
    margin: -1px;           /* cancel inner border gap on sides */
    border-bottom: 4px solid black;
  }

  :global(.dark) .nb-section-header {
    border-bottom: 4px solid #FFE500;
  }

  /* ── Summary link styling ── */
  .nb-summary :global(a) {
    font-weight: 900;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    color: #3A86FF;
  }

  .nb-summary :global(a:hover) {
    background-color: #FFE500;
    color: #000;
  }

  :global(.dark) .nb-summary :global(a) {
    color: #FFE500;
  }

  :global(.dark) .nb-summary :global(a:hover) {
    background-color: #FFE500;
    color: #000;
  }

  /* ── Print overrides ── */
  @media print {
    .nb-root {
      background: white !important;
      color: black !important;
    }

    .nb-text-shadow {
      text-shadow: 3px 3px 0px #FF006E;
    }

    .nb-img-shadow {
      box-shadow: 4px 4px 0px 0px #000;
    }

    .nb-section-header {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .nb-exp-card {
      break-inside: avoid;
    }

    .nb-cert-badge {
      break-inside: avoid;
    }
  }
</style>
