  .mn-gh-cell[data-level="1"] { background-color: #333; }
  .mn-gh-cell[data-level="2"] { background-color: #555; }
  .mn-gh-cell[data-level="3"] { background-color: #888; }
  .mn-gh-cell[data-level="4"] { background-color: #ccc; }

  /* Light mode colors */
  [data-mode="light"] .mn-gh-cell[data-level="0"] { background-color: #ebedf0; }
  [data-mode="light"] .mn-gh-cell[data-level="1"] { background-color: #c6c6c6; }
  [data-mode="light"] .mn-gh-cell[data-level="2"] { background-color: #8a8a8a; }
  [data-mode="light"] .mn-gh-cell[data-level="3"] { background-color: #555; }
