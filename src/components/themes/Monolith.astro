      padding: 0 !important;
      margin: 0 0 0.15in !important;
      min-height: 0 !important;
      border: none !important;
    }

    .mn-hero-inner {
      padding: 0 !important;
      max-width: 100% !important;
    }

    /* Hero summary gets a "Professional Summary" heading in print */
    .mn-hero-summary::before {
      content: "Professional Summary" !important;
      display: block !important;
      font-size: 14pt !important;
      font-weight: 700 !important;
      margin: 0 0 3pt !important;
      padding: 0 0 3pt !important;
      border-bottom: 1.5pt solid #000 !important;
    }

    .mn-hero-row {
      display: block !important;
    }

    .mn-hero-text {
      max-width: 100% !important;
    }

    .mn-hero-summary {
      font-size: 10pt !important;
      line-height: 1.4 !important;
      margin: 0 0 0.1in !important;
    }

    .mn-hero-photo-wrap {
      display: none !important;
    }

    /* Contact info in print */
