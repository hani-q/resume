---
import { resume, rfc1925Truths } from "../../data/resume";
import contributionsData from "../../data/contributions.json";

const educationParts = resume.education.split("|").map((p: string) => p.trim());

// Process contributions for the chart
const ghWeeks = contributionsData.weeks || [];
const monthLabels: { label: string; col: number }[] = [];
let lastMonth = -1;
const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
for (let w = 0; w < ghWeeks.length; w++) {
  const firstDay = ghWeeks[w].contributionDays[0];
  if (firstDay) {
    const month = new Date(firstDay.date).getMonth();
    if (month !== lastMonth) {
      monthLabels.push({ label: monthNames[month], col: w });
      lastMonth = month;
    }
  }
}
function ghLevel(count: number): number {
  if (count === 0) return 0;
  if (count <= 3) return 1;
  if (count <= 6) return 2;
  if (count <= 9) return 3;
  return 4;
}

const skillCategories = [
  { key: "programming", label: "Programming & Frameworks", items: resume.skills.programming },
  { key: "cloudDevops", label: "Cloud & DevOps", items: resume.skills.cloudDevops },
  { key: "networking", label: "Networking", items: resume.skills.networking },
  { key: "aiMl", label: "AI & Machine Learning", items: resume.skills.aiMl },
  { key: "databases", label: "Databases & Storage", items: resume.skills.databases },
  { key: "observability", label: "Observability", items: resume.skills.observability },
  { key: "security", label: "Security & Compliance", items: resume.skills.security },
  { key: "leadership", label: "Leadership & Delivery", items: resume.skills.leadership },
];

const totalCompanies = new Set(resume.experience.map((e: any) => e.company)).size;
const totalCerts = resume.certifications.length;

const sidebarItems = [
  { label: "Overview", icon: "person", href: "#profile" },
  { label: "Experience", icon: "work", href: "#experience" },
  { label: "Skills", icon: "terminal", href: "#skills" },
  { label: "Connect", icon: "alternate_email", href: "#contact" },
];

const navItems = [
  { label: "Overview", icon: "person", href: "#profile" },
  { label: "Experience", icon: "work", href: "#experience" },
  { label: "Skills", icon: "terminal", href: "#skills" },
  { label: "Certifications", icon: "verified", href: "#certifications" },
  { label: "Education", icon: "school", href: "#education" },
  { label: "Connect", icon: "alternate_email", href: "#contact" },
];
---

<div data-theme="monolith" class="mn-root">
  <!-- Google Fonts & Material Symbols -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=Dancing+Script:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

  <!-- Fixed Top Navigation Bar -->
  <nav class="mn-topnav">
    <div class="mn-topnav-inner">
      <a href="#profile" class="mn-topnav-logo">
        <span>{resume.name.split(" ")[0]}</span>
        <span>{resume.name.split(" ")[1]}</span>
      </a>
      <div class="mn-topnav-links">
        <a href="#profile" class="mn-topnav-link mn-topnav-link--active">Profile</a>
        <a href="#experience" class="mn-topnav-link">Experience</a>
        <a href="#skills" class="mn-topnav-link">Skills</a>
        <a href="#contact" class="mn-topnav-link">Contact</a>
        <a href="#" class="mn-topnav-link" id="mn-download-btn" role="button">Download</a>
        <a href="#" class="mn-topnav-link" id="mn-theme-toggle" role="button">Light</a>
      </div>
      <button class="mn-hamburger" aria-label="Toggle menu" onclick="document.querySelector('.mn-mobile-menu').classList.toggle('mn-mobile-menu--open')">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>

  <!-- Desktop Sidebar -->
  <aside class="mn-sidebar">
    <div class="mn-sidebar-header"></div>
    <nav class="mn-sidebar-nav">
      {sidebarItems.map((item, i) => (
        <a href={item.href} class:list={["mn-sidebar-link", { "mn-sidebar-link--active": i === 0 }]}>
          <span class="material-symbols-outlined" style={i === 0 ? "font-variation-settings: 'FILL' 1;" : ""}>{item.icon}</span>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
  </aside>

  <!-- Mobile Menu Overlay -->
  <div class="mn-mobile-menu">
    <nav class="mn-mobile-menu-nav">
      {navItems.map((item) => (
        <a href={item.href} class="mn-mobile-menu-link" onclick="document.querySelector('.mn-mobile-menu').classList.remove('mn-mobile-menu--open')">
          <span class="material-symbols-outlined">{item.icon}</span>
          <span>{item.label}</span>
        </a>
      ))}
      <a href="#" class="mn-mobile-menu-link" id="mn-download-btn-mobile" onclick="document.querySelector('.mn-mobile-menu').classList.remove('mn-mobile-menu--open')">
        <span class="material-symbols-outlined">download</span>
        <span>Download</span>
      </a>
    </nav>
  </div>

  <!-- Print-only resume header (hidden on screen) -->
  <div class="mn-print-header">
    <h1 class="mn-print-name">{resume.name}</h1>
    <div class="mn-print-contact">
      <span>{resume.email}</span>
      <span>{resume.phone}</span>
      <span>{resume.location}</span>
      <span>{resume.linkedin}</span>
    </div>
    <hr class="mn-print-divider" />
  </div>

  <!-- Main Content -->
  <main class="mn-main">

    <!-- Hero Section -->
    <section id="profile" class="mn-hero">
      <div class="mn-hero-inner">
        <span class="mn-hero-label">{resume.title}</span>
        <h2 class="mn-hero-headline" id="mn-hero-headline">Build. Lead. Ship.</h2>
        <div class="mn-hero-row">
          <div class="mn-hero-text">
            <div class="mn-hero-summary" set:html={resume.overview.summary} />
            <div class="mn-rfc-carousel" id="mn-rfc-carousel">
              <blockquote class="mn-rfc-quote">
                <p class="mn-rfc-text" id="mn-rfc-text"></p>
                <cite class="mn-rfc-cite">— <a href="https://www.rfc-editor.org/rfc/rfc1925" target="_blank" rel="noopener noreferrer">The Twelve Networking Truths</a>, <span id="mn-rfc-number"></span></cite>
              </blockquote>
            </div>
          </div>
          <div class="mn-hero-photo-wrap">
            <img src={resume.profileImage} alt={resume.name} class="mn-hero-photo" loading="eager" />
            <div class="mn-hero-photo-overlay"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bento Grid -->
    <section class="mn-bento">
      <div class="mn-bento-grid">
        <!-- Card 1: The Monolith Strategy (8 cols) -->
        <div class="mn-bento-card mn-bento-card--wide mn-bento-card--strategy">
          <div>
            <h3 class="mn-bento-strategy-title" id="mn-tagline-text">Architect. Build. Scale. Repeat.</h3>
            <p class="mn-bento-strategy-desc" id="mn-tagline-desc">Engineering Leader with deep expertise in Network Intelligence, Cloud Architecture, and Cyber Security. Building resilient systems that scale from startup to enterprise across global markets.</p>
          </div>
          <div class="mn-bento-strategy-stat">
            <span class="mn-bento-strategy-number">18+</span>
            <span class="mn-bento-strategy-label">Years of Deep <br/> Engineering Expertise</span>
          </div>
        </div>

        <!-- Card 2: Cloud Native (4 cols) -->
        <div class="mn-bento-card mn-bento-card--narrow mn-bento-card--variant">
          <span class="material-symbols-outlined mn-bento-icon">architecture</span>
          <h4 class="mn-bento-card-title">Cloud Native</h4>
          <p class="mn-bento-card-desc">AWS, OCI, GCP, OpenStack with triple AWS certifications and Infrastructure as Code expertise</p>
        </div>

        <!-- Card 3: Enterprise Products (4 cols) -->
        <div class="mn-bento-card mn-bento-card--narrow mn-bento-card--high">
          <span class="material-symbols-outlined mn-bento-icon">dns</span>
          <h4 class="mn-bento-card-title">Enterprise Products</h4>
          <p class="mn-bento-card-desc">Building on-prem appliance products deployed in customer data centers — network intelligence, DPI, and cyber security platforms</p>
        </div>

        <!-- Card 4: Team Mentorship (4 cols) -->
        <div class="mn-bento-card mn-bento-card--narrow mn-bento-card--variant">
          <span class="material-symbols-outlined mn-bento-icon">groups</span>
          <h4 class="mn-bento-card-title">Team Mentorship</h4>
          <p class="mn-bento-card-desc">Managing cross-functional engineering teams and establishing Centers of Excellence</p>
        </div>

        <!-- Card 5: Global Reach (4 cols) -->
        <div class="mn-bento-card mn-bento-card--narrow mn-bento-card--global">
          <span class="material-symbols-outlined mn-bento-icon">public</span>
          <h4 class="mn-bento-card-title">Global Reach</h4>
          <p class="mn-bento-card-desc">Work across UAE, KSA, USA, Sweden, and Pakistan in startup and enterprise environments</p>
        </div>

        <!-- Card 6: GitHub Contributions (full width) -->
        <div class="mn-bento-card mn-bento-card--full mn-bento-card--github" id="mn-github-card">
          <div class="mn-gh-months">
            {monthLabels.map((m) => (
              <span class="mn-gh-month" style={`grid-column: ${m.col + 1}`}>{m.label}</span>
            ))}
          </div>
          <div class="mn-gh-grid">
            <div class="mn-gh-days">
              <span></span><span>Mon</span><span></span><span>Wed</span><span></span><span>Fri</span><span></span>
            </div>
            <div class="mn-gh-weeks">
              {ghWeeks.map((week: any) => (
                <div class="mn-gh-week">
                  {week.contributionDays.map((day: any) => (
                    <div
                      class="mn-gh-cell"
                      data-level={ghLevel(day.contributionCount)}
                      title={`${day.date}: ${day.contributionCount} contributions`}
                    />
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="mn-experience">
      <div class="mn-experience-inner">
        <h2 class="mn-experience-heading">Professional Journey</h2>
        <div class="mn-experience-list">
          {resume.experience.map((job: any) => (
            <div class="mn-exp-item">
              <div class="mn-exp-date">
                <p class="mn-exp-period">{job.period}</p>
              </div>
              <div class="mn-exp-card-wrap">
                <div class="mn-exp-card">
                  <h3 class="mn-exp-title">{job.title}</h3>
                  <p class="mn-exp-company">{job.company}</p>
                  <p class="mn-exp-summary">{job.bullets[0]}</p>
                  {job.bullets.length > 1 && (
                    <ul class="mn-exp-bullets">
                      {job.bullets.slice(1).map((bullet: string) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="mn-skills">
      <div class="mn-skills-inner">
        <div class="mn-skills-header">
          <div>
            <h2 class="mn-skills-heading">Technical Proficiency</h2>
            <p class="mn-skills-subheading">A curated stack of modern technologies honed across 18+ years of engineering.</p>
          </div>
          <div class="mn-skills-watermark">SKILLS</div>
        </div>
        <div class="mn-skills-grid">
          {skillCategories.map((cat) => (
            <div class="mn-skill-group">
              <h4 class="mn-skill-category">{cat.label}</h4>
              <div class="mn-skill-pills">
                {cat.items.map((skill: string) => (
                  <span class="mn-skill-pill">{skill}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Certifications Section -->
    <section id="certifications" class="mn-certifications">
      <div class="mn-certifications-inner">
        <div class="mn-skills-header">
          <div>
            <h2 class="mn-skills-heading">Certifications</h2>
            <p class="mn-skills-subheading">Professional credentials and continuous learning.</p>
          </div>
          <div class="mn-skills-watermark">CERTS</div>
        </div>
        <div class="mn-certs-grid">
          {resume.certifications.map((cert: string) => {
            const parts = cert.split("|").map((p: string) => p.trim());
            return (
              <div class="mn-cert-card">
                <div class="mn-cert-name">{parts[0]}</div>
                <div class="mn-cert-meta">
                  <span class="mn-cert-issuer">{parts[1]}</span>
                  {parts[2] && <span class="mn-cert-year">{parts[2]}</span>}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Education Section -->
    <section id="education" class="mn-education">
      <div class="mn-education-inner">
        <h2 class="mn-experience-heading">Education</h2>
        <div class="mn-edu-card">
          <div class="mn-edu-degree">{educationParts[0]}</div>
          <div class="mn-edu-major">{educationParts[1]}</div>
          <div class="mn-edu-school">{educationParts[2]}</div>
          <div class="mn-edu-location">{educationParts[3]}</div>
          {educationParts[4] && <div class="mn-edu-year">{educationParts[4]}</div>}
        </div>

        <!-- Involvement / Volunteer -->
        <h2 class="mn-experience-heading" style="margin-top: 5rem;">Community Involvement</h2>
        <div class="mn-exp-item">
          <div class="mn-exp-date">
            <p class="mn-exp-period">{resume.involvement.period}</p>
          </div>
          <div class="mn-exp-card-wrap">
            <div class="mn-exp-card">
              <h3 class="mn-exp-title">{resume.involvement.role}</h3>
              <p class="mn-exp-company">{resume.involvement.organization}</p>
              <p class="mn-exp-summary">{resume.involvement.bullets[0]}</p>
              {resume.involvement.bullets.length > 1 && (
                <ul class="mn-exp-bullets">
                  {resume.involvement.bullets.slice(1).map((bullet: string) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="mn-contact">
      <div class="mn-contact-inner">
        <div class="mn-contact-left">
          <h2 class="mn-contact-heading">Ready to build <br/> the future?</h2>
          <p class="mn-contact-intro">I am always open to discussing new projects, creative ideas, or opportunities to be part of your vision.</p>
          <div class="mn-contact-items">
            <a href={`mailto:${resume.email}`} class="mn-contact-item">
              <div class="mn-contact-icon-box">
                <span class="material-symbols-outlined">mail</span>
              </div>
              <div>
                <p class="mn-contact-item-label">Email</p>
                <p class="mn-contact-item-value">{resume.email}</p>
              </div>
            </a>
            <a href={`tel:${resume.phone}`} class="mn-contact-item">
              <div class="mn-contact-icon-box">
                <span class="material-symbols-outlined">phone</span>
              </div>
              <div>
                <p class="mn-contact-item-label">Phone</p>
                <p class="mn-contact-item-value">{resume.phone}</p>
              </div>
            </a>
            <div class="mn-contact-item">
              <div class="mn-contact-icon-box">
                <span class="material-symbols-outlined">location_on</span>
              </div>
              <div>
                <p class="mn-contact-item-label">Location</p>
                <p class="mn-contact-item-value">{resume.location}</p>
              </div>
            </div>
            <a href={resume.linkedin} target="_blank" rel="noopener noreferrer" class="mn-contact-item">
              <div class="mn-contact-icon-box">
                <span class="material-symbols-outlined">open_in_new</span>
              </div>
              <div>
                <p class="mn-contact-item-label">LinkedIn</p>
                <p class="mn-contact-item-value">haniqurayshi</p>
              </div>
            </a>
          </div>
        </div>
        <div class="mn-contact-right">
          <form class="mn-contact-form" onsubmit="event.preventDefault()">
            <div class="mn-form-group">
              <label for="mn-name">Name</label>
              <input type="text" id="mn-name" name="name" placeholder="Jane Doe" autocomplete="name" />
            </div>
            <div class="mn-form-group">
              <label for="mn-email">Email</label>
              <input type="email" id="mn-email" name="email" placeholder="jane@example.com" autocomplete="email" />
            </div>
            <div class="mn-form-group">
              <label for="mn-subject">Subject</label>
              <input type="text" id="mn-subject" name="subject" placeholder="Project inquiry" />
            </div>
            <div class="mn-form-group">
              <label for="mn-message">Message</label>
              <textarea id="mn-message" name="message" rows={4} placeholder="Tell me about your project..."></textarea>
            </div>
            <button type="submit" class="mn-btn mn-btn--gradient mn-btn--full">Send Message</button>
          </form>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mn-footer">
      <div class="mn-footer-inner">
        <p class="mn-footer-copy">&copy; {new Date().getFullYear()} {resume.name}. Built for the Monolith.</p>
        <div class="mn-footer-links">
          <a href={resume.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href={resume.twitter} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href={`mailto:${resume.email}`}>Email</a>
        </div>
      </div>
    </footer>

  </main>

  <!-- Theme Toggle Script (inline to prevent FOUC) -->
  <script type="application/json" id="mn-rfc-data" set:html={JSON.stringify(rfc1925Truths)}></script>
  <script is:inline>
    (function() {
      var STORAGE_KEY = 'mn-theme-mode';
      var THEME_ATTR = 'data-mode';

      function getInitialMode() {
        var stored = localStorage.getItem(STORAGE_KEY);
        if (stored === 'light' || stored === 'dark') return stored;
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) return 'light';
        return 'dark';
      }

      function applyTheme(mode) {
        var root = document.querySelector('[data-theme="monolith"]') || document.documentElement;
        root.setAttribute(THEME_ATTR, mode);
        localStorage.setItem(STORAGE_KEY, mode);
        updateToggle(mode);
      }

      function updateToggle(mode) {
        var toggle = document.getElementById('mn-theme-toggle');
        if (!toggle) return;
        toggle.textContent = mode === 'light' ? 'Dark' : 'Light';
      }

      function toggleTheme() {
        var root = document.querySelector('[data-theme="monolith"]') || document.documentElement;
        var current = root.getAttribute(THEME_ATTR) || 'dark';
        applyTheme(current === 'light' ? 'dark' : 'light');
      }

      // Apply immediately
      applyTheme(getInitialMode());

      function handleDownload(e) {
        e.preventDefault();
        window.print();
      }

      // RFC 1925 carousel
      var rfcTruths = JSON.parse(document.getElementById('mn-rfc-data').textContent);
      var rfcIndex = Math.floor(Math.random() * rfcTruths.length);

      function showRfcTruth(index, animate) {
        var textEl = document.getElementById('mn-rfc-text');
        var numEl = document.getElementById('mn-rfc-number');
        var quoteEl = document.querySelector('.mn-rfc-quote');
        if (!textEl || !numEl || !quoteEl) return;
        var truth = rfcTruths[index];

        if (!animate) {
          textEl.textContent = truth.text;
          numEl.textContent = '#' + truth.number;
          return;
        }

        // Slide out to top
        quoteEl.classList.add('mn-rfc--exit');
        setTimeout(function() {
          textEl.textContent = truth.text;
          numEl.textContent = '#' + truth.number;
          // Position below, then slide in
          quoteEl.classList.remove('mn-rfc--exit');
          quoteEl.classList.add('mn-rfc--enter');
          // Force reflow
          void quoteEl.offsetHeight;
          quoteEl.classList.remove('mn-rfc--enter');
        }, 500);
      }

      function nextRfcTruth() {
        rfcIndex = (rfcIndex + 1) % rfcTruths.length;
        showRfcTruth(rfcIndex, true);
      }

      // Attach events
      document.addEventListener('DOMContentLoaded', function() {
        var toggle = document.getElementById('mn-theme-toggle');
        if (toggle) toggle.addEventListener('click', function(e) { e.preventDefault(); toggleTheme(); });
        var dlBtn = document.getElementById('mn-download-btn');
        if (dlBtn) dlBtn.addEventListener('click', handleDownload);
        var dlBtnMobile = document.getElementById('mn-download-btn-mobile');
        if (dlBtnMobile) dlBtnMobile.addEventListener('click', handleDownload);
        if (window.matchMedia) {
          window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function(e) {
            // Only follow system preference if user hasn't explicitly chosen a theme
            if (!localStorage.getItem(STORAGE_KEY)) {
              applyTheme(e.matches ? 'light' : 'dark');
            }
          });
        }

        // Initialize and start RFC carousel
        showRfcTruth(rfcIndex, false);
        setInterval(nextRfcTruth, 10000);

        // Tagline carousel
        var taglines = [
          { title: "Architect. Build. Scale. Repeat.", desc: "Engineering Leader with deep expertise in Network Intelligence, Cloud Architecture, and Cyber Security. Building resilient systems that scale from startup to enterprise across global markets." },
          { title: "Building Teams That Build Products.", desc: "From hiring the first engineer to structuring entire departments — designing org culture, delivery methodologies, and technical strategy from the ground up." },
          { title: "Engineering the Next Engineering.", desc: "Pioneering Agentic Software Engineering practices — integrating AI-assisted development, autonomous workflows, and intelligent tooling into modern engineering organizations." }
        ];
        var taglineIndex = 0;
        var taglineTitle = document.getElementById('mn-tagline-text');
        var taglineDesc = document.getElementById('mn-tagline-desc');

        function showTagline(index, animate) {
          if (!taglineTitle || !taglineDesc) return;
          var t = taglines[index];
          if (!animate) {
            taglineTitle.textContent = t.title;
            taglineDesc.textContent = t.desc;
            return;
          }
          taglineTitle.style.opacity = '0';
          taglineTitle.style.transform = 'translateY(-20px)';
          taglineDesc.style.opacity = '0';
          taglineDesc.style.transform = 'translateY(-20px)';
          setTimeout(function() {
            taglineTitle.textContent = t.title;
            taglineDesc.textContent = t.desc;
            taglineTitle.style.transform = 'translateY(20px)';
            taglineDesc.style.transform = 'translateY(20px)';
            void taglineTitle.offsetHeight;
            taglineTitle.style.opacity = '1';
            taglineTitle.style.transform = 'translateY(0)';
            taglineDesc.style.opacity = '1';
            taglineDesc.style.transform = 'translateY(0)';
          }, 500);
        }

        showTagline(0, false);
        setInterval(function() {
          taglineIndex = (taglineIndex + 1) % taglines.length;
          showTagline(taglineIndex, true);
        }, 8000);

        // Hero headline carousel
        var heroHeadlines = [
          "Build. Lead. Ship.",
          "From Packets to Products.",
          "18 Years of Shipping.",
          "Code Meets Leadership."
        ];
        var heroIndex = 0;
        var heroEl = document.getElementById('mn-hero-headline');

        function showHeroHeadline(index, animate) {
          if (!heroEl) return;
          if (!animate) {
            heroEl.textContent = heroHeadlines[index];
            return;
          }
          heroEl.style.opacity = '0';
          heroEl.style.transform = 'translateY(-30px)';
          setTimeout(function() {
            heroEl.textContent = heroHeadlines[index];
            heroEl.style.transform = 'translateY(30px)';
            void heroEl.offsetHeight;
            heroEl.style.opacity = '1';
            heroEl.style.transform = 'translateY(0)';
          }, 500);
        }

        showHeroHeadline(0, false);
        setInterval(function() {
          heroIndex = (heroIndex + 1) % heroHeadlines.length;
          showHeroHeadline(heroIndex, true);
        }, 6000);

        // GitHub card click
        var ghCard = document.getElementById('mn-github-card');
        if (ghCard) ghCard.addEventListener('click', function() {
          window.open('https://github.com/hani-q', '_blank');
        });

        // GitHub spotlight hover
        var ghCells = document.querySelectorAll('.mn-gh-cell');
        var ghGreens = ['', '#0e4429', '#006d32', '#26a641', '#39d353'];
        var ghGreensLight = ['', '#9be9a8', '#40c463', '#30a14e', '#216e39'];
        var spotlightRadius = 60; // pixels

        if (ghCard) {
          ghCard.addEventListener('mousemove', function(e) {
            var rect = ghCard.getBoundingClientRect();
            var mx = e.clientX;
            var my = e.clientY;
            for (var i = 0; i < ghCells.length; i++) {
              var cell = ghCells[i];
              var level = parseInt(cell.getAttribute('data-level') || '0');
              var cr = cell.getBoundingClientRect();
              var cx = cr.left + cr.width / 2;
              var cy = cr.top + cr.height / 2;
              var dist = Math.sqrt((mx - cx) * (mx - cx) + (my - cy) * (my - cy));
              if (level > 0 && dist < spotlightRadius) {
                var root = document.querySelector('[data-theme="monolith"]');
                var isLight = root && root.getAttribute('data-mode') === 'light';
                var greens = isLight ? ghGreensLight : ghGreens;
                var opacity = 1 - (dist / spotlightRadius);
                cell.style.backgroundColor = greens[level];
                cell.style.opacity = (0.5 + opacity * 0.5).toString();
              } else {
                cell.style.backgroundColor = '';
                cell.style.opacity = '';
              }
            }
          });

          ghCard.addEventListener('mouseleave', function() {
            for (var i = 0; i < ghCells.length; i++) {
              ghCells[i].style.backgroundColor = '';
              ghCells[i].style.opacity = '';
            }
          });
        }
      });
    })();
  </script>
</div>

