  /* ================================================================
     PRINT STYLES — ATS-friendly PDF via window.print()
     ================================================================ */
  @media print {
    /* Reset all colors and fonts for ATS */
    * {
      color: #000 !important;
      background: #fff !important;
      box-shadow: none !important;
      text-shadow: none !important;
      border-color: #ccc !important;
      font-family: Arial, Helvetica, sans-serif !important;
    }

    /* Page setup */
    @page {
      size: letter;
      margin: 0.6in 0.7in;
    }

    /* Hide non-resume elements */
    .mn-topnav,
    .mn-sidebar,
    .mn-mobile-menu,
    .mn-hamburger,
    .mn-footer,
    .mn-contact-form,
    .mn-contact-right,
    .mn-hero-actions,
    .mn-hero-photo-overlay,
    .mn-bento,
    .mn-skills-watermark,
    .mn-contact-heading,
    .mn-contact-intro,
    .mn-fab,
    .mn-hero-headline,
    .mn-hero-label,
    .mn-rfc-carousel,
    .mn-contact {
      display: none !important;
    }

    /* Print-only resume header */
    .mn-print-header {
      display: block !important;
      text-align: center !important;
      margin: 0 0 0.15in !important;
      padding: 0 !important;
    }

    .mn-print-name {
      font-size: 22pt !important;
      font-weight: 700 !important;
      margin: 0 0 4pt !important;
      text-transform: uppercase !important;
      letter-spacing: 1pt !important;
    }

    .mn-print-contact {
      display: flex !important;
      justify-content: center !important;
      flex-wrap: wrap !important;
      gap: 0 !important;
      font-size: 9.5pt !important;
      margin: 0 0 6pt !important;
    }

    .mn-print-contact span {
      white-space: nowrap !important;
    }

    .mn-print-contact span:not(:last-child)::after {
      content: " | " !important;
      margin: 0 4pt !important;
    }

    .mn-print-divider {
      border: none !important;
      border-top: 1.5pt solid #000 !important;
      margin: 0 0 6pt !important;
    }

    /* Remove layout constraints — single column */
    .mn-root,
    .mn-main {
      display: block !important;
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
    }

    .mn-main {
      margin-left: 0 !important;
    }

    /* Hero / Header — name and contact info */
