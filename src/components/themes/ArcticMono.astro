---
import { resume } from "../../data/resume";

const {
  name,
  title,
  location,
  email,
  phone,
  linkedin,
  twitter,
  profileImage,
  overview,
  skills,
  experience,
  certifications,
  education,
  involvement,
} = resume;

const educationParts = education.split(" | ");
const eduDegree = educationParts[0];
const eduField = educationParts[1];
const eduInstitution = educationParts[2];
const eduLocation = educationParts[3];
const eduYear = educationParts[4];
---

<div
  data-theme="arctic-mono"
  class="min-h-screen bg-[#f8f9fa] dark:bg-[#111111] text-black dark:text-white font-['Inter',sans-serif] transition-colors duration-300"
>
  <div class="max-w-5xl mx-auto px-8 py-16 md:px-16">

    <!-- ============================================================ -->
    <!-- HEADER                                                        -->
    <!-- ============================================================ -->
    <header class="mb-16">
      <div class="flex items-start gap-8">
        <!-- Profile image: small, square, grayscale -->
        <div class="flex-shrink-0">
          <img
            src={profileImage}
            alt={name}
            class="w-20 h-20 object-cover grayscale contrast-110 brightness-95"
            style="aspect-ratio: 1/1;"
          />
        </div>

        <!-- Name / role block -->
        <div class="flex-1 min-w-0">
          <h1 class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-none text-black dark:text-white">
            {name}
          </h1>
          <p class="mt-2 text-sm font-normal tracking-widest uppercase text-neutral-500 dark:text-neutral-400">
            {title}
          </p>

          <!-- Contact row -->
          <div class="mt-5 flex flex-wrap items-center gap-x-6 gap-y-2">
            <!-- Location -->
            <span class="flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400 tracking-wide">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>
              </svg>
              {location}
            </span>

            <!-- Email -->
            <a
              href={`mailto:${email}`}
              class="flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400 tracking-wide hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              {email}
            </a>

            <!-- Phone -->
            <a
              href={`tel:${phone}`}
              class="flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400 tracking-wide hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {phone}
            </a>

            <!-- LinkedIn -->
            <a
              href={linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400 tracking-wide hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              <svg role="img" viewBox="0 0 24 24" class="w-3 h-3 flex-shrink-0 fill-current" xmlns="http://www.w3.org/2000/svg">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>

            <!-- X / Twitter -->
            <a
              href={twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400 tracking-wide hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              <svg role="img" viewBox="0 0 24 24" class="w-3 h-3 flex-shrink-0 fill-current" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
              </svg>
              X
            </a>
          </div>
        </div>
      </div>

      <!-- Full-width rule below header -->
      <div class="mt-10 h-px bg-black dark:bg-white"></div>
    </header>

    <!-- ============================================================ -->
    <!-- 01. OVERVIEW                                                   -->
    <!-- ============================================================ -->
    <section class="mb-14">
      <!-- Section label -->
      <div class="flex items-baseline gap-4 mb-6">
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-blue-600 dark:text-blue-400 tabular-nums">01.</span>
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-black dark:text-white">Overview</span>
        <div class="flex-1 h-px bg-neutral-300 dark:bg-neutral-700"></div>
      </div>

      <!-- Two-col grid: label left, content right -->
      <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
        <div class="pt-0.5">
          <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-neutral-400 dark:text-neutral-500">Summary</p>
        </div>
        <div>
          <p class="text-sm leading-relaxed text-neutral-700 dark:text-neutral-300 [&_a]:text-blue-600 [&_a]:dark:text-blue-400 [&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-blue-300 [&_a]:dark:decoration-blue-700" set:html={overview.summary} />
        </div>
      </div>

      <!-- Highlights -->
      <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start mt-6">
        <div class="pt-0.5">
          <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-neutral-400 dark:text-neutral-500">Highlights</p>
        </div>
        <ul class="space-y-2">
          {overview.highlights.map((h) => (
            <li class="flex items-start gap-3 text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">
              <span class="mt-2 w-1 h-1 flex-shrink-0 bg-blue-600 dark:bg-blue-400"></span>
              {h}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 02. SKILLS                                                     -->
    <!-- ============================================================ -->
    <section class="mb-14">
      <div class="flex items-baseline gap-4 mb-6">
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-blue-600 dark:text-blue-400 tabular-nums">02.</span>
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-black dark:text-white">Skills</span>
        <div class="flex-1 h-px bg-neutral-300 dark:bg-neutral-700"></div>
      </div>

      <div class="space-y-4">
        <!-- Programming -->
        <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
          <div class="pt-1">
            <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-neutral-400 dark:text-neutral-500">Programming</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {skills.programming.map((s) => (
              <span class="px-2.5 py-1 text-[11px] font-medium tracking-wide uppercase bg-white dark:bg-neutral-900 border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300">
                {s}
              </span>
            ))}
          </div>
        </div>

        <!-- Cloud / DevOps -->
        <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
          <div class="pt-1">
            <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-neutral-400 dark:text-neutral-500">Cloud / DevOps</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {skills.cloudDevops.map((s) => (
              <span class="px-2.5 py-1 text-[11px] font-medium tracking-wide uppercase bg-white dark:bg-neutral-900 border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300">
                {s}
              </span>
            ))}
          </div>
        </div>

        <!-- Networking -->
        <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
          <div class="pt-1">
            <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-neutral-400 dark:text-neutral-500">Networking</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {skills.networking.map((s) => (
              <span class="px-2.5 py-1 text-[11px] font-medium tracking-wide uppercase bg-white dark:bg-neutral-900 border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300">
                {s}
              </span>
            ))}
          </div>
        </div>

        <!-- AI / ML -->
        <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
          <div class="pt-1">
            <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-neutral-400 dark:text-neutral-500">AI / ML</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {skills.aiMl.map((s) => (
              <span class="px-2.5 py-1 text-[11px] font-medium tracking-wide uppercase bg-white dark:bg-neutral-900 border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300">
                {s}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 03. EXPERIENCE                                                 -->
    <!-- ============================================================ -->
    <section class="mb-14">
      <div class="flex items-baseline gap-4 mb-6">
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-blue-600 dark:text-blue-400 tabular-nums">03.</span>
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-black dark:text-white">Experience</span>
        <div class="flex-1 h-px bg-neutral-300 dark:bg-neutral-700"></div>
      </div>

      <div class="space-y-10">
        {experience.map((job, idx) => (
          <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
            <!-- Left: date + location metadata -->
            <div class="pt-0.5 space-y-1">
              <p class="text-[11px] font-semibold leading-snug text-neutral-600 dark:text-neutral-400 tabular-nums">
                {job.period.split(" - ")[0]}
              </p>
              <p class="text-[11px] text-neutral-400 dark:text-neutral-500">
                — {job.period.split(" - ")[1] || "Present"}
              </p>
              <p class="text-[10px] tracking-wide text-neutral-400 dark:text-neutral-500 pt-1 leading-tight">
                {job.location}
              </p>
            </div>

            <!-- Right: role, company, bullets -->
            <div>
              <div class="flex items-baseline gap-3 flex-wrap">
                <h3 class="text-sm font-bold uppercase tracking-wide text-black dark:text-white">
                  {job.title}
                </h3>
                <span class="text-[10px] font-semibold tracking-widest uppercase text-blue-600 dark:text-blue-400">
                  {job.company}
                </span>
              </div>

              <ul class="mt-3 space-y-2">
                {job.bullets.map((b) => (
                  <li class="flex items-start gap-3 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                    <span class="mt-2 w-1 h-1 flex-shrink-0 bg-neutral-400 dark:bg-neutral-600"></span>
                    {b}
                  </li>
                ))}
              </ul>

              <!-- Thin rule between entries (not after last) -->
              {idx < experience.length - 1 && (
                <div class="mt-10 h-px bg-neutral-200 dark:bg-neutral-800"></div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 04. CERTIFICATIONS                                             -->
    <!-- ============================================================ -->
    <section class="mb-14">
      <div class="flex items-baseline gap-4 mb-6">
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-blue-600 dark:text-blue-400 tabular-nums">04.</span>
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-black dark:text-white">Certifications</span>
        <div class="flex-1 h-px bg-neutral-300 dark:bg-neutral-700"></div>
      </div>

      <div class="space-y-3">
        {certifications.map((cert) => {
          const parts = cert.split(" | ");
          const certName = parts[0];
          const issuer = parts[1];
          const year = parts[2];
          return (
            <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
              <div class="pt-0.5">
                <p class="text-[11px] font-semibold tabular-nums text-neutral-500 dark:text-neutral-400">{year}</p>
                <p class="text-[10px] tracking-wide text-neutral-400 dark:text-neutral-500 leading-tight mt-0.5">{issuer}</p>
              </div>
              <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-snug pt-0.5">{certName}</p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 05. EDUCATION                                                  -->
    <!-- ============================================================ -->
    <section class="mb-14">
      <div class="flex items-baseline gap-4 mb-6">
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-blue-600 dark:text-blue-400 tabular-nums">05.</span>
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-black dark:text-white">Education</span>
        <div class="flex-1 h-px bg-neutral-300 dark:bg-neutral-700"></div>
      </div>

      <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
        <div class="pt-0.5">
          <p class="text-[11px] font-semibold tabular-nums text-neutral-500 dark:text-neutral-400">{eduYear}</p>
          <p class="text-[10px] tracking-wide text-neutral-400 dark:text-neutral-500 leading-tight mt-0.5">{eduLocation}</p>
        </div>
        <div>
          <p class="text-sm font-bold uppercase tracking-wide text-black dark:text-white">{eduDegree}</p>
          <p class="text-[11px] font-semibold tracking-widest uppercase text-blue-600 dark:text-blue-400 mt-0.5">{eduField}</p>
          <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-1">{eduInstitution}</p>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 06. INVOLVEMENT                                                -->
    <!-- ============================================================ -->
    <section class="mb-14">
      <div class="flex items-baseline gap-4 mb-6">
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-blue-600 dark:text-blue-400 tabular-nums">06.</span>
        <span class="text-xs font-bold tracking-[0.25em] uppercase text-black dark:text-white">Community</span>
        <div class="flex-1 h-px bg-neutral-300 dark:bg-neutral-700"></div>
      </div>

      <div class="grid grid-cols-[9rem_1fr] gap-x-10 items-start">
        <!-- Left -->
        <div class="pt-0.5 space-y-1">
          <p class="text-[11px] font-semibold text-neutral-600 dark:text-neutral-400">
            {involvement.period.split(" - ")[0]}
          </p>
          <p class="text-[11px] text-neutral-400 dark:text-neutral-500">
            — {involvement.period.split(" - ")[1] || "Present"}
          </p>
          <p class="text-[10px] tracking-wide text-neutral-400 dark:text-neutral-500 pt-1 leading-tight">
            {involvement.location}
          </p>
        </div>

        <!-- Right -->
        <div>
          <div class="flex items-baseline gap-3 flex-wrap">
            <h3 class="text-sm font-bold uppercase tracking-wide text-black dark:text-white">
              {involvement.role}
            </h3>
            <span class="text-[10px] font-semibold tracking-widest uppercase text-blue-600 dark:text-blue-400">
              {involvement.organization}
            </span>
          </div>
          <ul class="mt-3 space-y-2">
            {involvement.bullets.map((b) => (
              <li class="flex items-start gap-3 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                <span class="mt-2 w-1 h-1 flex-shrink-0 bg-neutral-400 dark:bg-neutral-600"></span>
                {b}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- FOOTER                                                         -->
    <!-- ============================================================ -->
    <footer class="mt-16">
      <div class="h-px bg-black dark:bg-white mb-6"></div>
      <div class="flex items-center justify-between">
        <p class="text-[10px] font-semibold tracking-[0.3em] uppercase text-neutral-400 dark:text-neutral-500">
          {name}
        </p>
        <p class="text-[10px] tracking-widest uppercase text-neutral-400 dark:text-neutral-500">
          {new Date().getFullYear()}
        </p>
      </div>
    </footer>

  </div>
</div>
