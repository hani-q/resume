---
const themes = [
  { id: "suspended-in-ink", label: "Suspended in Ink", color: "bg-gray-900", desc: "Dark editorial with serif accents" },
  { id: "paper-trail", label: "Paper Trail", color: "bg-amber-50", desc: "Warm paper-like minimal design" },
  { id: "terminal-green", label: "Terminal", color: "bg-green-900", desc: "Retro hacker terminal aesthetic" },
  { id: "arctic-mono", label: "Arctic Mono", color: "bg-slate-100", desc: "Clean, cold monochrome" },
  { id: "neo-brutalist", label: "Neo Brutalist", color: "bg-yellow-300", desc: "Bold, raw, high-contrast" },
];
---

<div class="no-print fixed bottom-4 right-4 z-[200]" id="theme-panel">
  <!-- Toggle button -->
  <button
    id="theme-panel-toggle"
    class="w-10 h-10 rounded-full bg-black/80 dark:bg-white/20 text-white flex items-center justify-center shadow-lg backdrop-blur-md hover:scale-110 transition-transform"
    aria-label="Toggle theme panel"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
  </button>

  <!-- Panel -->
  <div
    id="theme-panel-content"
    class="hidden absolute bottom-14 right-0 w-72 bg-black/90 dark:bg-white/10 backdrop-blur-xl rounded-xl shadow-2xl border border-white/10 p-4 space-y-3"
  >
    <div class="flex items-center justify-between mb-2">
      <h3 class="text-white text-sm font-semibold tracking-wide uppercase">Themes</h3>
      <div class="flex gap-2">
        <!-- Dark mode toggle -->
        <button
          onclick="toggleDarkMode()"
          class="text-white/70 hover:text-white transition-colors"
          aria-label="Toggle dark mode"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        </button>
        <!-- PDF download -->
        <button
          onclick="downloadPDF()"
          class="text-white/70 hover:text-white transition-colors"
          aria-label="Download PDF"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        </button>
      </div>
    </div>

    {themes.map((theme) => (
      <button
        data-theme-btn={theme.id}
        onclick={`setTheme('${theme.id}')`}
        class="w-full flex items-center gap-3 p-2 rounded-lg hover:bg-white/10 transition-colors group text-left"
      >
        <div class={`w-8 h-8 rounded-lg ${theme.color} border border-white/20 shrink-0`} />
        <div>
          <div class="text-white text-sm font-medium">{theme.label}</div>
          <div class="text-white/50 text-xs">{theme.desc}</div>
        </div>
      </button>
    ))}
  </div>
</div>

<script>
  const toggle = document.getElementById("theme-panel-toggle");
  const content = document.getElementById("theme-panel-content");

  toggle?.addEventListener("click", () => {
    content?.classList.toggle("hidden");
  });

  // Close when clicking outside
  document.addEventListener("click", (e) => {
    const panel = document.getElementById("theme-panel");
    if (panel && !panel.contains(e.target as Node)) {
      content?.classList.add("hidden");
    }
  });
</script>
