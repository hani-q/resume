---
import { resume } from "../../data/resume";
---

<div
  data-theme="suspended-in-ink"
  class="min-h-screen bg-[#0f0f0f] text-[#e8e4dc] font-sans"
  style="font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;"
>

  <!-- ═══════════════════════════════════════════════
       SIDEBAR (fixed, lg screens only)
  ═══════════════════════════════════════════════ -->
  <aside class="hidden lg:flex fixed top-0 left-0 h-screen w-64 flex-col bg-[#0a0a0a] border-r border-white/[0.06] z-10 overflow-y-auto">

    <!-- Profile photo -->
    <div class="px-6 pt-8 pb-6 flex flex-col items-center">
      <div class="w-28 h-28 rounded-full overflow-hidden border border-white/10 shadow-lg mb-4">
        <img
          src={resume.profileImage}
          alt={resume.name}
          class="w-full h-full object-cover grayscale opacity-90"
        />
      </div>
      <p class="text-xs text-white/30 tracking-widest uppercase text-center leading-relaxed">
        {resume.title}
      </p>
    </div>

    <div class="border-t border-white/[0.06] mx-6"></div>

    <!-- Skills -->
    <div class="px-6 py-6 flex-1">
      <h3 class="text-[10px] tracking-[0.2em] uppercase text-white/30 font-medium mb-4">Skills</h3>

      <!-- Programming -->
      <div class="mb-5">
        <p class="text-[10px] tracking-[0.15em] uppercase text-[#7c6cfc]/70 font-medium mb-2">Programming</p>
        <div class="flex flex-wrap gap-1.5">
          {resume.skills.programming.map((skill) => (
            <span class="text-[11px] text-white/60 bg-white/[0.05] border border-white/[0.08] rounded px-2 py-0.5 leading-tight">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- Cloud & DevOps -->
      <div class="mb-5">
        <p class="text-[10px] tracking-[0.15em] uppercase text-[#7c6cfc]/70 font-medium mb-2">Cloud & DevOps</p>
        <div class="flex flex-wrap gap-1.5">
          {resume.skills.cloudDevops.map((skill) => (
            <span class="text-[11px] text-white/60 bg-white/[0.05] border border-white/[0.08] rounded px-2 py-0.5 leading-tight">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- Networking -->
      <div class="mb-5">
        <p class="text-[10px] tracking-[0.15em] uppercase text-[#7c6cfc]/70 font-medium mb-2">Networking</p>
        <div class="flex flex-wrap gap-1.5">
          {resume.skills.networking.map((skill) => (
            <span class="text-[11px] text-white/60 bg-white/[0.05] border border-white/[0.08] rounded px-2 py-0.5 leading-tight">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- AI / ML -->
      <div class="mb-5">
        <p class="text-[10px] tracking-[0.15em] uppercase text-[#7c6cfc]/70 font-medium mb-2">AI / ML</p>
        <div class="flex flex-wrap gap-1.5">
          {resume.skills.aiMl.map((skill) => (
            <span class="text-[11px] text-white/60 bg-white/[0.05] border border-white/[0.08] rounded px-2 py-0.5 leading-tight">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Sidebar footer: location -->
    <div class="border-t border-white/[0.06] mx-6"></div>
    <div class="px-6 py-5">
      <p class="text-[11px] text-white/30 leading-relaxed flex items-start gap-2">
        <svg class="shrink-0 mt-0.5 opacity-50" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        {resume.location}
      </p>
    </div>
  </aside>

  <!-- ═══════════════════════════════════════════════
       MAIN CONTENT (offset by sidebar width on lg)
  ═══════════════════════════════════════════════ -->
  <main class="lg:ml-64 min-h-screen">

    <!-- ─── HEADER ─────────────────────────────── -->
    <header class="relative px-8 md:px-14 lg:px-16 pt-14 pb-10 border-b border-white/[0.06]">
      <!-- Decorative top rule -->
      <div class="w-10 h-[2px] bg-[#7c6cfc] mb-8"></div>

      <!-- Name -->
      <h1
        class="text-5xl md:text-6xl lg:text-7xl font-serif font-bold leading-none tracking-tight text-white mb-3"
        style="font-family: 'Georgia', 'Times New Roman', serif; letter-spacing: -0.02em;"
      >
        {resume.name}
      </h1>

      <!-- Title -->
      <p class="text-base md:text-lg text-white/40 tracking-widest uppercase font-light mb-8" style="letter-spacing: 0.18em;">
        {resume.title}
      </p>

      <!-- Contact row -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-white/50">

        <!-- Email -->
        <a
          href={`mailto:${resume.email}`}
          class="flex items-center gap-2 hover:text-white/80 transition-colors duration-200 group"
        >
          <svg class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          {resume.email}
        </a>

        <span class="text-white/15 select-none hidden sm:inline">·</span>

        <!-- Phone -->
        <a
          href={`tel:${resume.phone}`}
          class="flex items-center gap-2 hover:text-white/80 transition-colors duration-200 group"
        >
          <svg class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.82 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.29 6.29l.82-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {resume.phone}
        </a>

        <span class="text-white/15 select-none hidden sm:inline">·</span>

        <!-- LinkedIn -->
        <a
          href={resume.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 hover:text-white/80 transition-colors duration-200 group"
          aria-label="LinkedIn"
        >
          <svg class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="text-[13px]">LinkedIn</span>
        </a>

        <span class="text-white/15 select-none hidden sm:inline">·</span>

        <!-- X / Twitter -->
        <a
          href={resume.twitter}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 hover:text-white/80 transition-colors duration-200 group"
          aria-label="X / Twitter"
        >
          <svg class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
          </svg>
          <span class="text-[13px]">@haniq313</span>
        </a>
      </div>

      <!-- Mobile location badge -->
      <div class="mt-6 lg:hidden flex items-center gap-2 text-xs text-white/30">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        {resume.location}
      </div>
    </header>

    <!-- ─── CONTENT SECTIONS ───────────────────── -->
    <div class="px-8 md:px-14 lg:px-16 py-10 space-y-14 max-w-4xl">

      <!-- ══ PROFESSIONAL OVERVIEW ══════════════ -->
      <section>
        <div class="sticky top-0 z-20 -mx-8 md:-mx-14 lg:-mx-16 px-8 md:px-14 lg:px-16 py-3 mb-6"
             style="background: rgba(15,15,15,0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
          <h2 class="text-[10px] tracking-[0.25em] uppercase text-[#7c6cfc] font-semibold">
            Professional Overview
          </h2>
        </div>

        <!-- Summary -->
        <p class="text-[15px] leading-relaxed text-white/75 mb-6 max-w-2xl" set:html={resume.overview.summary} />

        <!-- Highlights -->
        <ul class="space-y-2.5">
          {resume.overview.highlights.map((h) => (
            <li class="flex items-start gap-3 text-[14px] text-white/60 leading-relaxed">
              <span class="mt-[7px] w-1 h-1 rounded-full bg-[#7c6cfc]/60 shrink-0"></span>
              {h}
            </li>
          ))}
        </ul>
      </section>

      <hr class="border-white/[0.06]" />

      <!-- ══ EXPERIENCE ════════════════════════ -->
      <section>
        <div class="sticky top-0 z-20 -mx-8 md:-mx-14 lg:-mx-16 px-8 md:px-14 lg:px-16 py-3 mb-6"
             style="background: rgba(15,15,15,0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
          <h2 class="text-[10px] tracking-[0.25em] uppercase text-[#7c6cfc] font-semibold">
            Experience
          </h2>
        </div>

        <div class="space-y-5">
          {resume.experience.map((exp) => (
            <div
              class="group relative pl-5 border-l-2 border-[#2a2340] hover:border-[#7c6cfc] transition-all duration-300 hover:bg-white/[0.02] rounded-r-lg py-4 pr-4 -ml-0 cursor-default"
              style="transition: border-color 0.3s ease, background 0.3s ease;"
            >
              <!-- Role + Company -->
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
                <h3 class="text-[15px] font-semibold text-white/90 group-hover:text-white transition-colors duration-200">
                  {exp.title}
                </h3>
                <span class="text-[11px] text-white/30 font-mono shrink-0">{exp.period}</span>
              </div>

              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-3">
                <span class="text-[13px] text-[#7c6cfc]/80 font-medium">{exp.company}</span>
                <span class="text-white/20 text-xs">·</span>
                <span class="text-[12px] text-white/35">{exp.location}</span>
              </div>

              <!-- Bullets -->
              <ul class="space-y-1.5">
                {exp.bullets.map((b) => (
                  <li class="flex items-start gap-2.5 text-[13px] text-white/55 leading-relaxed group-hover:text-white/65 transition-colors duration-200">
                    <span class="mt-[7px] w-[3px] h-[3px] rounded-full bg-white/25 shrink-0"></span>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <hr class="border-white/[0.06]" />

      <!-- ══ CERTIFICATIONS ════════════════════ -->
      <section>
        <div class="sticky top-0 z-20 -mx-8 md:-mx-14 lg:-mx-16 px-8 md:px-14 lg:px-16 py-3 mb-6"
             style="background: rgba(15,15,15,0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
          <h2 class="text-[10px] tracking-[0.25em] uppercase text-[#7c6cfc] font-semibold">
            Certifications
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {resume.certifications.map((cert) => {
            const parts = cert.split(" | ");
            const name = parts[0];
            const issuer = parts[1];
            const year = parts[2];
            return (
              <div class="flex items-start gap-3 p-3.5 bg-white/[0.025] border border-white/[0.06] rounded-lg hover:border-white/[0.12] hover:bg-white/[0.04] transition-all duration-200 group">
                <div class="mt-0.5 w-1.5 h-1.5 rounded-full bg-[#7c6cfc]/50 shrink-0 group-hover:bg-[#7c6cfc] transition-colors duration-200"></div>
                <div>
                  <p class="text-[13px] text-white/80 font-medium leading-snug">{name}</p>
                  <p class="text-[11px] text-white/35 mt-0.5">
                    {issuer}{year ? ` · ${year}` : ""}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </section>

      <hr class="border-white/[0.06]" />

      <!-- ══ EDUCATION ══════════════════════════ -->
      <section>
        <div class="sticky top-0 z-20 -mx-8 md:-mx-14 lg:-mx-16 px-8 md:px-14 lg:px-16 py-3 mb-6"
             style="background: rgba(15,15,15,0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
          <h2 class="text-[10px] tracking-[0.25em] uppercase text-[#7c6cfc] font-semibold">
            Education
          </h2>
        </div>

        {(() => {
          const parts = resume.education.split(" | ");
          const degree = parts[0];
          const field = parts[1];
          const institution = parts[2];
          const location = parts[3];
          const year = parts[4];
          return (
            <div class="pl-5 border-l-2 border-[#2a2340] hover:border-[#7c6cfc] transition-all duration-300 py-4 pr-4 group">
              <h3 class="text-[15px] font-semibold text-white/90 group-hover:text-white transition-colors duration-200 mb-1">
                {degree}{field ? ` — ${field}` : ""}
              </h3>
              <p class="text-[13px] text-[#7c6cfc]/80 mb-0.5">{institution}</p>
              <div class="flex flex-wrap gap-x-3 text-[12px] text-white/35">
                {location && <span>{location}</span>}
                {year && <span>· {year}</span>}
              </div>
            </div>
          );
        })()}
      </section>

      <hr class="border-white/[0.06]" />

      <!-- ══ INVOLVEMENT ════════════════════════ -->
      <section class="pb-16">
        <div class="sticky top-0 z-20 -mx-8 md:-mx-14 lg:-mx-16 px-8 md:px-14 lg:px-16 py-3 mb-6"
             style="background: rgba(15,15,15,0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
          <h2 class="text-[10px] tracking-[0.25em] uppercase text-[#7c6cfc] font-semibold">
            Involvement
          </h2>
        </div>

        <div class="pl-5 border-l-2 border-[#2a2340] hover:border-[#7c6cfc] transition-all duration-300 py-4 pr-4 group">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
            <h3 class="text-[15px] font-semibold text-white/90 group-hover:text-white transition-colors duration-200">
              {resume.involvement.role}
            </h3>
            <span class="text-[11px] text-white/30 font-mono shrink-0">{resume.involvement.period}</span>
          </div>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-3">
            <span class="text-[13px] text-[#7c6cfc]/80 font-medium">{resume.involvement.organization}</span>
            <span class="text-white/20 text-xs">·</span>
            <span class="text-[12px] text-white/35">{resume.involvement.location}</span>
          </div>
          <ul class="space-y-1.5">
            {resume.involvement.bullets.map((b) => (
              <li class="flex items-start gap-2.5 text-[13px] text-white/55 leading-relaxed group-hover:text-white/65 transition-colors duration-200">
                <span class="mt-[7px] w-[3px] h-[3px] rounded-full bg-white/25 shrink-0"></span>
                {b}
              </li>
            ))}
          </ul>
        </div>
      </section>

    </div><!-- /content -->
  </main><!-- /main -->

  <!-- Mobile skills drawer (shown below header on small screens) -->
  <div class="lg:hidden border-t border-white/[0.06] bg-[#0a0a0a] px-8 py-6">
    <h3 class="text-[10px] tracking-[0.2em] uppercase text-white/30 font-medium mb-4">Skills</h3>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <p class="text-[10px] tracking-[0.15em] uppercase text-[#7c6cfc]/70 font-medium mb-2">Programming</p>
        <div class="flex flex-wrap gap-1.5">
          {resume.skills.programming.map((skill) => (
            <span class="text-[11px] text-white/60 bg-white/[0.05] border border-white/[0.08] rounded px-2 py-0.5">{skill}</span>
          ))}
        </div>
      </div>
      <div>
        <p class="text-[10px] tracking-[0.15em] uppercase text-[#7c6cfc]/70 font-medium mb-2">Cloud & DevOps</p>
        <div class="flex flex-wrap gap-1.5">
          {resume.skills.cloudDevops.map((skill) => (
            <span class="text-[11px] text-white/60 bg-white/[0.05] border border-white/[0.08] rounded px-2 py-0.5">{skill}</span>
          ))}
        </div>
      </div>
      <div>
        <p class="text-[10px] tracking-[0.15em] uppercase text-[#7c6cfc]/70 font-medium mb-2">Networking</p>
        <div class="flex flex-wrap gap-1.5">
          {resume.skills.networking.map((skill) => (
            <span class="text-[11px] text-white/60 bg-white/[0.05] border border-white/[0.08] rounded px-2 py-0.5">{skill}</span>
          ))}
        </div>
      </div>
      <div>
        <p class="text-[10px] tracking-[0.15em] uppercase text-[#7c6cfc]/70 font-medium mb-2">AI / ML</p>
        <div class="flex flex-wrap gap-1.5">
          {resume.skills.aiMl.map((skill) => (
            <span class="text-[11px] text-white/60 bg-white/[0.05] border border-white/[0.08] rounded px-2 py-0.5">{skill}</span>
          ))}
        </div>
      </div>
    </div>
  </div>

</div>
